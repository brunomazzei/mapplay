# ─── Back4App (Parse Server) ─────────────────────────────────
# Encontre em: Back4App Dashboard > App Settings > Security & Keys
VITE_PARSE_APP_ID=your_back4app_app_id
VITE_PARSE_JS_KEY=your_back4app_js_key

# ─── Firebase (Google OAuth + Push Notifications) ────────────
# Encontre em: Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# VAPID Public Key — para web push (opcional)
# Encontre em: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Esta chave é PÚBLICA e pode ser versionada no git se necessário
VITE_FIREBASE_VAPID_KEY=your_vapid_public_key

# ─── CHAVES QUE NÃO VÃO NO .env ─────────────────────────────
# As seguintes chaves são configuradas DIRETAMENTE no painel, não aqui:
#
# FCM Server Key (para push Android via Back4App):
#   → Back4App Dashboard > Push Notifications > Android > FCM Server Key
#   → Encontre em: Firebase Console > Project Settings > Cloud Messaging > Server key
#
# google-services.json (para build Android nativo com Capacitor):
#   → Baixe em: Firebase Console > Project Settings > Your apps > Android app
#   → Coloque o arquivo em: android/app/google-services.json
